{
  "name": "control-stock",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && wrangler dev",
    "dev:web": "vite",
    "dev:api": "wrangler dev",
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "typecheck": "tsc -p tsconfig.worker.json --noEmit && tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "db:create": "wrangler d1 create control-stock",
    "db:migrate:local": "wrangler d1 migrations apply control-stock --local",
    "db:migrate:remote": "wrangler d1 migrations apply control-stock --remote",
    "db:seed:local": "wrangler d1 execute control-stock --local --file=./seed/seed.sql",
    "db:seed:remote": "wrangler d1 execute control-stock --remote --file=./seed/seed.sql",
    "db:reset:local": "wrangler d1 execute control-stock --local --file=./seed/reset.sql",
    "db:reset:remote": "wrangler d1 execute control-stock --remote --file=./seed/reset.sql",
    "db:demo:gen": "node seed/gen_demo.mjs",
    "db:demo:local": "wrangler d1 execute control-stock --local --file=./seed/demo.sql",
    "db:demo:remote": "wrangler d1 execute control-stock --remote --file=./seed/demo.sql"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "qrcode-generator": "^2.0.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0",
    "xlsx-js-style": "^1.2.0"
  }
}
